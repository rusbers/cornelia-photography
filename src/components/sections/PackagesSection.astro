---
import Heading from "../Heading.astro"
import Package from "../Package.astro"
import { PACKAGES } from "@/lib/data/packages"
---

<div class="hero-section container">
  <Heading as="h1" subheading="Packages" className="mb-12"
    >The prices I offer are <span class="italic-text">amazing</span></Heading
  >
  <ul class="grid grid-cols-1 gap-6 lg:grid-cols-3 xl:px-12">
    {
      PACKAGES.map((servicePackage) => (
        <li class="mx-auto sm:max-w-96">
          <Package servicePackage={servicePackage} />
        </li>
      ))
    }
  </ul>
</div>
