---
import { cn } from "@/lib/utils"
import type { CommonProps } from "../lib/types"
import { ICON_COLOR } from "../lib/constants"

type Props = CommonProps

const { classes } = Astro.props
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  class={cn("size-5 shrink-0", classes)}
  viewBox="0 0 24 24"
  fill="none"
  stroke={ICON_COLOR}
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
>
  <circle cx="12" cy="12" r="10" fill={ICON_COLOR}></circle>
  <path d="m9 12 2 2 4-4" stroke="#fff"></path>
</svg>
